# =============================================================
# Detailly - Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================

# Application
NODE_ENV=development

# Backend API
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
# DB_TYPE steuert den Treiber:
#   sqlite   -> lokale Datei, KEINE externe DB noetig (Standard fuer die Demo)
#   postgres -> klassische PostgreSQL-Verbindung (siehe DB_HOST etc.)
DB_TYPE=sqlite

# SQLite (nur bei DB_TYPE=sqlite relevant)
DB_DATABASE=detailly.db

# PostgreSQL (nur bei DB_TYPE=postgres relevant)
DB_HOST=localhost
DB_PORT=5432
DB_USER=detailly
DB_PASS=detailly
DB_NAME=detailly

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend
# Single-Origin-Betrieb (empfohlen, z.B. gehostete Demo):
#   Leer lassen! Dann ruft das Frontend die API ueber RELATIVE Pfade auf
#   (/api/v1/...) und wird vom selben Backend ausgeliefert. So gibt es kein
#   "failed to fetch" mehr, weil Frontend und API auf derselben Adresse laufen.
# Getrennte Entwicklung (Frontend auf :3000, Backend auf :3001):
#   NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=Detailly

# sevdesk Integration (Platzhalter/Stub)
# Ohne Token arbeitet der SevdeskService als No-op (nur Logging).
# SEVDESK_API_TOKEN=your-sevdesk-api-token
# SEVDESK_BASE_URL=https://my.sevdesk.de/api/v1

# Optional: Email (Sprint 2+)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
