# =============================================================
# Detailly - Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================

# Application
NODE_ENV=development

# Backend API
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
# DB_TYPE steuert den Treiber:
#   sqlite   -> lokale Datei, KEINE externe DB noetig (Standard fuer die Demo)
#   postgres -> klassische PostgreSQL-Verbindung (siehe DB_HOST etc.)
DB_TYPE=sqlite

# SQLite (nur bei DB_TYPE=sqlite relevant)
DB_DATABASE=detailly.db

# PostgreSQL (nur bei DB_TYPE=postgres relevant)
DB_HOST=localhost
DB_PORT=5432
DB_USER=detailly
DB_PASS=detailly
DB_NAME=detailly

# Authentication
# In Production MUSS JWT_SECRET >= 16 Zeichen lang sein UND darf KEIN bekannter
# Dev-Default sein (sonst bricht die ENV-Validierung den Boot ab).
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Feld-Verschluesselung (AES-256-GCM) sensibler Spalten (IBAN/Steuernummer,
# Rechnungs-Empfaenger, interne Notizen, sevdesk-Token). In Production PFLICHT
# (>= 32 Zeichen, ideal 64 Hex = 32 Byte). Erzeugen: `openssl rand -hex 32`.
# ACHTUNG: Schluesselverlust = die verschluesselten Daten sind unwiederbringlich!
# In Dev optional (sicherer interner Fallback).
# DATA_ENC_KEY=

# Erst-Admin-Passwort fuer den Seed (npm run seed). Ohne Wert wird das oeffentlich
# bekannte Demo-Passwort 'Detailly2026!' gesetzt -> in Prod IMMER setzen.
# SEED_ADMIN_PASSWORD=ein-starkes-passwort

# Stripe (Self-Service-Abo / Zahlung) - OPTIONAL
# Ohne STRIPE_SECRET_KEY ist das Billing komplett deaktiviert (kein Crash).
# Live-Keys NUR ins ENV, nie in Code/DB. Webhook-Endpunkt im Stripe-Dashboard:
#   https://DEINE-DOMAIN/api/v1/billing/webhook  -> STRIPE_WEBHOOK_SECRET hierher.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Basis-URL fuer Stripe-Redirects (success/cancel/return). Fallback: FRONTEND_URL.
# APP_BASE_URL=https://deine-domain.de

# Frontend
# Single-Origin-Betrieb (empfohlen, z.B. gehostete Demo):
#   Leer lassen! Dann ruft das Frontend die API ueber RELATIVE Pfade auf
#   (/api/v1/...) und wird vom selben Backend ausgeliefert. So gibt es kein
#   "failed to fetch" mehr, weil Frontend und API auf derselben Adresse laufen.
# Getrennte Entwicklung (Frontend auf :3000, Backend auf :3001):
#   NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=Detailly

# sevdesk Integration (Platzhalter/Stub)
# Ohne Token arbeitet der SevdeskService als No-op (nur Logging).
# SEVDESK_API_TOKEN=your-sevdesk-api-token
# SEVDESK_BASE_URL=https://my.sevdesk.de/api/v1

# Email / SMTP (optional)
# Ohne SMTP_HOST versendet der MailService nichts (loggt nur) - kein Crash.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
# MAIL_FROM=Detailly <no-reply@detailly.de>
