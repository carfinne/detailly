# =============================================================
# Detailly - Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================

# Application
NODE_ENV=development

# Backend API
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=detailly
DB_PASS=detailly
DB_NAME=detailly

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Detailly

# sevdesk Integration (Sprint 1+)
# SEVDESK_API_TOKEN=your-sevdesk-api-token
# SEVDESK_BASE_URL=https://my.sevdesk.de/api/v1

# Optional: Email (Sprint 2+)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
